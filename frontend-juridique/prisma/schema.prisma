generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Courrier {
  id           String   @id @default(cuid())
  categorie    String   
  provenance   String   
  reference    String   
  objet        String   
  fichierUrl   String?  
  statut       String   @default("EN_ATTENTE") 
  dateCreation DateTime @default(now())
}